generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum Species {
  DOG
  CAT
  BIRD
  RABBIT
  OTHER
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum AnimalSize {
  SMALL
  MEDIUM
  LARGE
}

enum PostType {
  FOUND_STRAY
  REHOME_OWNED_PET
  TEMP_HOME_NEEDED
}

enum PostStatus {
  DRAFT
  ACTIVE
  PENDING
  ADOPTED
  CLOSED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  REMOVED
}

enum NotificationType {
  REQUEST_CREATED
  REQUEST_APPROVED
  REQUEST_REJECTED
  POST_SAVED
  SYSTEM
}

model User {
  id                   String                 @id @default(uuid())
  fullName             String
  email                String                 @unique
  phone                String?
  passwordHash         String
  role                 UserRole               @default(USER)
  profileImageUrl      String?
  city                 String?
  district             String?
  bio                  String?
  isVerified           Boolean                @default(false)
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  refreshTokens        RefreshToken[]
  createdPets          Pet[]                  @relation("PetCreatedBy")
  posts                PetPost[]              @relation("PostOwner")
  adoptionRequests     AdoptionRequest[]      @relation("RequestApplicant")
  requestStatusChanges RequestStatusHistory[] @relation("RequestChangedBy")
  savedPosts           SavedPost[]
  postComments         PostComment[]
  postReportsCreated   PostReport[]           @relation("ReportCreatedBy")
  postReportsReviewed  PostReport[]           @relation("ReportReviewedBy")
  notifications        Notification[]

  @@index([role])
  @@index([isActive])
  @@index([city, district])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Pet {
  id                 String      @id @default(uuid())
  createdByUserId    String
  name               String?
  species            Species
  breed              String?
  gender             Gender      @default(UNKNOWN)
  estimatedAgeMonths Int?
  size               AnimalSize?
  color              String?
  description        String?
  healthSummary      String?
  vaccinationSummary String?
  isNeutered         Boolean     @default(false)
  specialNeedsNote   String?
  temperament        String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  createdBy          User        @relation("PetCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  posts              PetPost[]

  @@index([createdByUserId])
  @@index([species])
  @@index([gender])
  @@index([size])
}

model PetPost {
  id               String            @id @default(uuid())
  petId            String
  ownerUserId      String
  postType         PostType
  title            String
  description      String
  city             String
  district         String?
  addressNote      String?
  latitude         Decimal?          @db.Decimal(9, 6)
  longitude        Decimal?          @db.Decimal(9, 6)
  status           PostStatus        @default(DRAFT)
  isUrgent         Boolean           @default(false)
  viewCount        Int               @default(0)
  publishedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  closedAt         DateTime?
  pet              Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner            User              @relation("PostOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  images           PostImage[]
  adoptionRequests AdoptionRequest[]
  savedBy          SavedPost[]
  comments         PostComment[]
  reports          PostReport[]

  @@index([petId])
  @@index([ownerUserId])
  @@index([postType])
  @@index([status])
  @@index([city, district])
  @@index([publishedAt])
  @@index([status, postType])
  @@index([isUrgent])
}

model PostImage {
  id        String   @id @default(uuid())
  postId    String
  imageUrl  String
  publicId  String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  post      PetPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([postId, isPrimary])
}

model AdoptionRequest {
  id                 String                 @id @default(uuid())
  postId             String
  applicantUserId    String
  status             RequestStatus          @default(PENDING)
  message            String
  housingType        String?
  hasOtherPets       Boolean                @default(false)
  hasChildren        Boolean                @default(false)
  experienceWithPets String?
  whyAdopt           String?
  contactPhone       String?
  reviewedAt         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  post               PetPost                @relation(fields: [postId], references: [id], onDelete: Cascade)
  applicant          User                   @relation("RequestApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  statusHistory      RequestStatusHistory[]

  @@index([postId])
  @@index([applicantUserId])
  @@index([status])
  @@index([postId, status])
  @@index([applicantUserId, status])
}

model RequestStatusHistory {
  id              String          @id @default(uuid())
  requestId       String
  oldStatus       RequestStatus?
  newStatus       RequestStatus
  changedByUserId String
  note            String?
  changedAt       DateTime        @default(now())
  request         AdoptionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  changedBy       User            @relation("RequestChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([requestId])
  @@index([changedByUserId])
  @@index([changedAt])
}

model SavedPost {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      PetPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      PetPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([isVisible])
}

model PostReport {
  id               String       @id @default(uuid())
  postId           String
  reportedByUserId String
  reviewedByUserId String?
  reason           String
  description      String?
  status           ReportStatus @default(OPEN)
  createdAt        DateTime     @default(now())
  reviewedAt       DateTime?
  post             PetPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  reportedBy       User         @relation("ReportCreatedBy", fields: [reportedByUserId], references: [id], onDelete: Cascade)
  reviewedBy       User?        @relation("ReportReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([reportedByUserId])
  @@index([reviewedByUserId])
  @@index([status])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
}
